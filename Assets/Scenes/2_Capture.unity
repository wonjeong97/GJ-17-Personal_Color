      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 27
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\"\uAC15\uB82C\uD558\uACE0 \uC120\uBA85\uD558\uAC8C \uC874\uC7AC\uAC10\uC744
    \uB4DC\uB7EC\uB0B4\uB294 \uD0C0\uC785\"\u200B\r\n\r\n\uBE44\uBE44\uB4DC\uD558\uACE0
    \uB300\uBE44 \uAC15\uD55C \uCEEC\uB7EC\uAC00 \uC774\uBAA9\uAD6C\uBE44\uB97C \uAC00\uC7A5
    \uC785\uCCB4\uC801\uC774\uACE0 \uD654\uB824\uD558\uAC8C \uC0B4\uB824\uC90D\uB2C8\uB2E4.
    \u200B\r\n\r\n\uCA0D\uD558\uACE0 \uAC15\uB82C\uD55C \uCEEC\uB7EC\uC77C\uC218\uB85D
    \uB354\uC6B1 \uBE5B\uC744 \uBC1C\uD558\uB294 \uD0C0\uC785\uC785\uB2C8\uB2E4.\u200B\r\n\r\n\uC5B4\uC6B8\uB9AC\uB294
    \uC0C9\uC0C1 : \uD478\uC2DC\uC544 \uD551\uD06C \xB7 \uC5D0\uBA54\uB784\uB4DC
    \uADF8\uB9B0 \xB7 \uD2B8\uB8E8 \uBE14\uB8E8 \u200B\r\n\r\n\uC2A4\uD0C0\uC77C\uB9C1
    \uD301 : \uBE14\uB799 \uC564 \uD654\uC774\uD2B8 \uC758\uC0C1\uC5D0 \uBE44\uBE44\uB4DC\uD55C
    \uCEEC\uB7EC \uD3EC\uC778\uD2B8 \uC544\uC774\uD15C \uD558\uB098\uBA74\n\uC644\uBCBD\uD55C
    \uC2A4\uD0C0\uC77C\uB9C1 \uC644\uC131\uC774\uC5D0\uC694. \u200B\r\n\r\n#\uAC15\uB82C\uD55C
    #\uC784\uD329\uD2B8\uC788\uB294 #\uD654\uB824\uD55C\u200B"
