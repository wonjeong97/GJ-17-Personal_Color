--- !u!114 &188749903
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 188749901}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 27
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\"\uB300\uC9C0\uCC98\uB7FC \uD3EC\uADFC\uD558\uACE0 \uC790\uC5F0\uC2A4\uB7EC\uC6B4
    \uD0C0\uC785\"\u200B\r\n\r\n\uD0C1\uAE30\uAC00 \uB3C4\uB294 \uB530\uB73B\uD55C
    \uC5B4\uC2A4\uD1A4\uC774 \uD53C\uBD80\uB97C \uAC00\uC7A5 \uD3B8\uC548\uD558\uACE0
    \uB0B4\uCD94\uB7F4\uD558\uAC8C \uB9CC\uB4E4\uC5B4\uC90D\uB2C8\uB2E4.\n\uC790\uC5F0\uC5D0\uC11C
    \uC628 \uC0C9\uC77C\uC218\uB85D \uB354\uC6B1 \uC870\uD654\uB86D\uAC8C \uBE5B\uB098\uB294
    \uD0C0\uC785\uC785\uB2C8\uB2E4.\u200B\r\n\r\n\uC5B4\uC6B8\uB9AC\uB294 \uC0C9\uC0C1
    : \uCE74\uD0A4 \xB7 \uBA38\uC2A4\uD130\uB4DC \xB7 \uC18C\uD504\uD2B8 \uBCA0\uC774\uC9C0
    \u200B\r\n\r\n\uC2A4\uD0C0\uC77C\uB9C1 \uD301 : \uD1A4 \uC628 \uD1A4 \uC2A4\uD0C0\uC77C\uB9C1\uC774
    \uAC00\uC7A5 \uC6B0\uC544\uD558\uAC8C \uC5B4\uC6B8\uB9AC\uACE0,\n\uC740\uC740\uD55C
    \uD53C\uCE58 \uBE0C\uB77C\uC6B4 \uC74C\uC601 \uBA54\uC774\uD06C\uC5C5\uC774 \uBD84\uC704\uAE30\uB97C
    \uB354\uD574\uC918\uC694. \u200B\r\n\r\n#\uC790\uC5F0\uC2A4\uB7EC\uC6B4 #\uB0B4\uCD94\uB7F4\uD55C
    #\uB530\uB73B\uD55C\u200B"
