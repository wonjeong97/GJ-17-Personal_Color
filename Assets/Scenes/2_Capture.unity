--- !u!114 &2078793689
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2078793687}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 27
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\"\uBD04\uAF43\uCC98\uB7FC \uD654\uC0AC\uD558\uAC8C \uD53C\uC5B4\uB098\uB294
    \uD0C0\uC785\"\u200B\r\n\r\n\uCC44\uB3C4 \uB192\uACE0 \uB9D1\uC740 \uBE44\uBE44\uB4DC
    \uCEEC\uB7EC\uAC00 \uC774\uBAA9\uAD6C\uBE44\uB97C \uAC00\uC7A5 \uB610\uB837\uD558\uACE0
    \uD65C\uAE30\uCC28\uAC8C \uC0B4\uB824\uC90D\uB2C8\uB2E4. \u200B\r\n\r\n\uCA0D\uD558\uACE0
    \uD1B5\uD1B5 \uD280\uB294 \uCEEC\uB7EC\uC77C\uC218\uB85D \uB354\uC6B1 \uBE5B\uB098\uB294
    \uD0C0\uC785\uC785\uB2C8\uB2E4.\u200B\r\n\r\n\uC5B4\uC6B8\uB9AC\uB294 \uC0C9\uC0C1
    : \uCF54\uB784 \xB7 \uC120\uD50C\uB77C\uC6CC \uC610\uB85C\uC6B0 \xB7 \uB77C\uC784
    \uADF8\uB9B0 \u200B\r\n\r\n\uC2A4\uD0C0\uC77C\uB9C1 \uD301 : \uACFC\uC999 \uBA38\uAE08\uC740
    \uB4EF\uD55C \uCD09\uCD09\uD55C \uBA54\uC774\uD06C\uC5C5\uC774 \uCC30\uB5A1,\n\uB300\uBE44\uB418\uB294
    \uC0C9\uC0C1\uC758 \uCEEC\uB7EC \uBE14\uB85C\uD0B9 \uC2A4\uD0C0\uC77C\uB9C1\uB3C4
    \uD6CC\uB96D\uD558\uAC8C \uC18C\uD654\uD574\uC694. \u200B\r\n\r\n#\uBC1C\uB784\uD55C
    #\uD654\uC0AC\uD55C #\uD1B5\uD1B5\uD280\uB294"
