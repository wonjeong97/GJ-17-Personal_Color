  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 27
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\"\uCC28\uAC11\uACE0 \uBB35\uC9C1\uD55C \uCE74\uB9AC\uC2A4\uB9C8\uB97C
    \uAC00\uC9C4 \uD0C0\uC785\"\u200B\r\n\r\n\uBE14\uB799\uC774 \uAE4A\uAC8C \uC11E\uC778
    \uB2E4\uD06C\uD55C \uC0C9\uC870\uAC00 \uB3C4\uD68C\uC801\uC774\uACE0 \uAC15\uC778\uD55C
    \uB9E4\uB825\uC744 \uC644\uC131\uC2DC\uCF1C \uC90D\uB2C8\uB2E4. \u200B\r\n\r\n\uC5B4\uB461\uACE0
    \uCC28\uAC00\uC6B4 \uCEEC\uB7EC\uC77C\uC218\uB85D \uD2B9\uC720\uC758 \uAC78\uD06C\uB7EC\uC2DC
    \uB9E4\uB825\uC774 \uADF9\uB300\uD654\uB418\uB294 \uD0C0\uC785\uC785\uB2C8\uB2E4.\u200B\r\n\r\n\uC5B4\uC6B8\uB9AC\uB294
    \uC0C9\uC0C1 : \uB2E4\uD06C \uB124\uC774\uBE44 \xB7 \uB525 \uBC84\uAC74\uB514
    \xB7 \uCC28\uCF5C \uADF8\uB808\uC774 \u200B\r\n\r\n\uC2A4\uD0C0\uC77C\uB9C1 \uD301
    : \uC9D9\uC740 \uD50C\uB7FC\xB7\uBC84\uAC74\uB514 \uB9BD\uC774 \uBCF8\uC778 \uC785\uC220\uCC98\uB7FC
    \uC790\uC5F0\uC2A4\uB7FD\uAC8C \uC5B4\uC6B8\uB9AC\uACE0,\n\uD07C\uC9C1\uD55C
    \uC2E4\uBC84 \uC561\uC138\uC11C\uB9AC\uAC00 \uCE74\uB9AC\uC2A4\uB9C8\uB97C \uB354\uD574\uC918\uC694.
    \u200B\r\n\r\n#\uC138\uB828\uB41C #\uAC78\uD06C\uB7EC\uC2DC #\uCE74\uB9AC\uC2A4\uB9C8\uC788\uB294\u200B"
