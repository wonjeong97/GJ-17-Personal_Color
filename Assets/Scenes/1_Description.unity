    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 85
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "\uC0AC\uB78C\uC740 \uB204\uAD6C\uB098 \uD0DC\uC5B4\uB0A0 \uB54C\uBD80\uD130
    \uD53C\uBD80, \uB208\uB3D9\uC790, \uBA38\uB9AC\uCE74\uB77D\uC5D0 \uC790\uC2E0\uB9CC\uC758
    \uACE0\uC720\uD55C \uC0C9\uC744 \uAC00\uC9D1\uB2C8\uB2E4.\u200B\r\r\n\uD37C\uC2A4\uB110
    \uCEEC\uB7EC\uB780, \uC774 \uC2E0\uCCB4 \uACE0\uC720\uC758 \uC0C9\uACFC \uAC00\uC7A5
    \uC870\uD654\uB86D\uAC8C \uC5B4\uC6B0\uB7EC\uC9C0\uB294 \uC0C9\uC0C1 \uCCB4\uACC4\uB97C
    \uB73B\uD569\uB2C8\uB2E4.\u200B\r\r\n\uB611\uAC19\uC740 \uC0C9\uC758 \uC637\uB3C4
    \uC0AC\uB78C\uB9C8\uB2E4 \uB2E4\uB974\uAC8C \uBCF4\uC774\uB294 \uC774\uC720\uB294
    \uB2E8\uC21C\uD55C \uCDE8\uD5A5 \uCC28\uC774\uAC00 \uC544\uB2D9\uB2C8\uB2E4.
    \u200B\r\r\n\uBC14\uB85C \uD53C\uBD80\uAC00 \uBC18\uC0AC\uD558\uB294 \uBE5B\uC758
    \uD30C\uC7A5\uACFC \uD53C\uBD80 \uC18D \uC5B8\uB354\uD1A4(undertone)\uC774 \uB2E4\uB974\uAE30
    \uB54C\uBB38\uC785\uB2C8\uB2E4."
