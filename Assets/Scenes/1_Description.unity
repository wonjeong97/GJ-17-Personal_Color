    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 52
    m_Alignment: 3
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 1
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "STEP 1 \uC5BC\uAD74 \uC601\uC5ED \u2014 \uAC10\uC9C0 AI\uAC00 \uCD2C\uC601\uB41C
    \uC0AC\uC9C4\uC5D0\uC11C \uC5BC\uAD74\uC744 \uC778\uC2DD\uD558\uACE0 \uD53C\uBD80
    \uBD84\uC11D\uC5D0 \uCD5C\uC801\uD654\uB41C T\uC874\xB7U\uC874 \uC601\uC5ED\uC744
    \uBD84\uB9AC\uD569\uB2C8\uB2E4\u200B\r.\r\nSTEP 2 \uC0C9\uC0C1 \uB370\uC774\uD130
    \uCD94\uCD9C \u2014 \uC870\uBA85\uACFC \uADF8\uB9BC\uC790\uC758 \uC601\uD5A5\uC744
    \uBCF4\uC815\uD55C \uD6C4 \uD53C\uBD80\uC758 \uC21C\uC218\uD55C \uC0C9\uC0C1\uAC12(\uBA85\uB3C4\xB7\uCC44\uB3C4\xB7\uC0C9\uC0C1)\uC744
    \uC218\uCE58\uB85C \uCE21\uC815\uD569\uB2C8\uB2E4.\nSTEP 3 \uC5B8\uB354\uD1A4
    \uD310\uBCC4 \u2014 \uCE21\uC815\uB41C \uC0C9\uC0C1 \uB370\uC774\uD130\uB97C
    \uBC14\uD0D5\uC73C\uB85C \uD53C\uBD80\uAC00 \uC6DC\uD1A4\uC778\uC9C0 \uCFE8\uD1A4\uC778\uC9C0
    \uD310\uBCC4\uD569\uB2C8\uB2E4\u200B\r.\r\nSTEP 4 \uC720\uD615 \uACB0\uC815 \u2014
    \uBC1D\uAE30\xB7\uB530\uB73B\uD568\xB7\uC120\uBA85\uB3C4 3\uAC00\uC9C0 \uCD95\uC744
    \uC885\uD569 \uBD84\uC11D\uD574 \uBD04\xB7\uC5EC\uB984\xB7\uAC00\uC744\xB7\uACA8\uC6B8
    \uC911 \uB098\uC758 \uC720\uD615\uC744 \uACB0\uC815\uD569\uB2C8\uB2E4."
